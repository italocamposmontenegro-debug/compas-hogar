# ============================================
# Casa Clara — Variables de Entorno
# ============================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side — solo para Edge Functions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Mercado Pago Chile
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token
MERCADOPAGO_PUBLIC_KEY=your-mp-public-key

# Configuración de la app
APP_BASE_URL=http://localhost:5173

# SMTP (correo transaccional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=hola@casaclara.cl
