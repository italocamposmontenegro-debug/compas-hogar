# ============================================
# Compás Hogar — Variables de Entorno
# ============================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side — solo para Edge Functions)
# Usa CASA_CLARA_SUPABASE_SERVER_KEY como secret editable en Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CASA_CLARA_SUPABASE_SERVER_KEY=your-server-secret-key

# Mercado Pago Chile
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token
MERCADOPAGO_PUBLIC_KEY=your-mp-public-key
MP_WEBHOOK_URL=https://your-project.supabase.co/functions/v1/mp-webhook
MP_ACCOUNT_LABEL=mp_default
MP_PLAN_BASE_MONTHLY=your-base-monthly-plan-id
MP_PLAN_BASE_YEARLY=your-base-yearly-plan-id
MP_PLAN_PLUS_MONTHLY=your-plus-monthly-plan-id
MP_PLAN_PLUS_YEARLY=your-plus-yearly-plan-id

# Configuración de la app
APP_BASE_URL=http://localhost:5173

# SMTP (correo transaccional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=hola@casaclara.cl
SMTP_FROM_NAME=Compás Hogar
